layout {
    focus-ring {
        active-color "#96d5a6"
        inactive-color "#8b938a"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#96d5a6"
        inactive-color "#8b938a"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#96d5a6"
        inactive-color "#8b938a"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#96d5a680"
    }
}

